{
  "name": "ultra-ui",
  "private": true,
  "version": "1.1.0",
  "description": "Open-source monorepo for the Ultra UI React component library.",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@testing-library/react": "^16.3.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "pnpm": "^8.0.0",
    "react-dom": "^18.3.1",
    "typescript": "^5",
    "vite": "^5.0.0"
    ,"vitest": "^3.2.4"
  },
  "scripts": {
    "bootstrap": "pnpm -w install",
    "dev:showcase": "pnpm --filter @ultra-ui/showcase dev",
    "build": "pnpm -r --filter '!@ultra-ui/showcase' run build",
    "build:showcase": "pnpm build && pnpm --filter @ultra-ui/showcase run build",
    "build:packages": "pnpm -r --filter '!@ultra-ui/showcase' run build",
    "pack:check": "pnpm -r --filter @ultra-ui/primitives --filter @ultra-ui/headless --filter @ultra-ui/grid-core --filter @ultra-ui/tailwind-wrappers --filter @ultra-ui/ultra-table exec npm pack --dry-run",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint": "echo \"lint configuration pending\""
  },
  "keywords": [],
  "author": "Suraj Sawat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surajrsawat/ultra-ui.git"
  },
  "homepage": "https://github.com/surajrsawat/ultra-ui",
  "bugs": {
    "url": "https://github.com/surajrsawat/ultra-ui/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@types/react": "^19.2.14",
    "react": "^18.3.1"
  }
}
