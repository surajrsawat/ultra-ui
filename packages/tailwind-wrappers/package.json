{
  "name": "@ultra-ui/tailwind-wrappers",
  "version": "1.1.0",
  "description": "Tailwind-first component wrappers built on top of Ultra UI primitives.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
