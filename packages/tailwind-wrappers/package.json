      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/surajrsawat/ultra-ui.git",
    "directory": "packages/tailwind-wrappers"
  },
  "homepage": "https://github.com/surajrsawat/ultra-ui/tree/main/packages/tailwind-wrappers",
  "bugs": {
    "url": "https://github.com/surajrsawat/ultra-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir dist"
  }
}